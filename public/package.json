{
  "name": "@furkantunali/public",
  "config": {
    "outputPath": "./"
  },
  "scripts": {
    "dev": "npm run build && concurrently \"npm run watch-scss\" \"npm run watch-html\"",
    "build:watch": "concurrently \"npm run watch-scss\" \"npm run watch-html\"",
    "watch-scss": "sass --watch scss/:styles/",
    "watch-html": "nodemon",
    "build": "concurrently \"npm run build-scss\" \"npm run build-html\"",
    "build-scss": "sass --no-source-map scss/:styles/",
    "build-html-cv": "node build/merge-cv.js cv.json cv-merged.json && ejsc \"./**/*.ejs\" --out . --data-file ./.tmp/cv-merged.json",
    "build-html-cv-doc": "node build/merge-cv.js cv-doc.json cv-doc-merged.json && ejsc \"./**/*.ejs\" --out . --data-file ./.tmp/cv-doc-merged.json",
    "mv-cv-doc": "mv ./cv.html ./cv-doc.html && echo 'cv.html moved to cv-doc.html'",
    "build-html": "npm run build-html-cv-doc && npm run mv-cv-doc && npm run build-html-cv",
    "serve": "firebase serve",
    "deploy": "firebase deploy --only hosting --project furkantunali-1043",
    "predeploy": "npm run build",
    "logs": "firebase hosting:log"
  },
  "engines": {
    "node": "20"
  },
  "devDependencies": {
    "@wcj/ejs-cli": "^1.1.6",
    "sass": "^1.71.0",
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  },
  "private": true
}
