<!doctype html>
<html lang="">
  <head>
    <% 
      const data = GLOBEL || {};
      const meta = data.meta || {};
      const toArray = function(value) { return Array.isArray(value) ? value : []; };
      const isYouTubeHref = function(href) {
        return typeof href === 'string' && /^(https?:\/\/)?(www\.)?(youtube\.com|youtu\.be)\//i.test(href);
      };
      const isEmailHref = function(href) {
        return typeof href === 'string' && /^mailto:/i.test(href);
      };
      const shouldRenderLinkQr = function(href) {
        return false;
      };
      const getQrCodeUrl = function(href) {
        return 'https://api.qrserver.com/v1/create-qr-code/?size=96x96&margin=0&data=' + encodeURIComponent(href);
      };
    %>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="<%= meta.description || '' %>" />
    <title><%= meta.title || 'CV' %></title>

    <% if (!data.cvDoc) { %>
    <!-- Apple Touch Icons -->
    <link
      rel="apple-touch-icon"
      sizes="57x57"
      href="icons/apple-touch-icon-57x57.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="60x60"
      href="icons/apple-touch-icon-60x60.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="72x72"
      href="icons/apple-touch-icon-72x72.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="76x76"
      href="icons/apple-touch-icon-76x76.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href="icons/apple-touch-icon-114x114.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="icons/apple-touch-icon-120x120.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href="icons/apple-touch-icon-144x144.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="icons/apple-touch-icon-152x152.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="icons/apple-touch-icon-180x180.png"
    />
    <link
      rel="icon"
      type="image/png"
      href="icons/favicon-32x32.png"
      sizes="32x32"
    />
    <link
      rel="icon"
      type="image/png"
      href="icons/android-chrome-192x192.png"
      sizes="192x192"
    />
    <link
      rel="icon"
      type="image/png"
      href="icons/favicon-96x96.png"
      sizes="96x96"
    />
    <link
      rel="icon"
      type="image/png"
      href="icons/favicon-16x16.png"
      sizes="16x16"
    />
    <link rel="manifest" href="icons/manifest.json" />
    <!-- Safari Pinned Tab Icon -->
    <link rel="mask-icon" href="icons/safari-pinned-tab.svg" color="#5bbad5" />

    <!-- Microsoft Tile -->
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="msapplication-TileImage" content="icons/mstile-144x144.png" />
    <meta name="theme-color" content="#ffffff" />
    <% } %>

    <!-- Stylesheets -->
    <link rel="stylesheet" href="styles/cv.css" />
    <% if (data.cv) { %>
    <link rel="stylesheet" href="styles/cv-web.css?v=20260329-shadow5" />
    <% } %>
    <% if (data.cvDoc) { %>
    <link rel="stylesheet" href="styles/cv-doc.css" />
    <% } %>
    <style>
      @media print {
        header {
          display: flex !important;
          flex-direction: row !important;
          align-items: flex-start !important;
        }
        header hgroup {
          flex: 1 1 auto !important;
          min-width: 0 !important;
        }
        .page-qr-print {
          flex: 0 0 auto !important;
          float: none !important;
          position: static !important;
          margin: 0 0 0 0.12cm !important;
          line-height: 0 !important;
          order: 2 !important;
          align-self: flex-start !important;
        }
        .page-qr-print__box {
          width: 1.4cm !important;
          height: 1.4cm !important;
          border-width: 0.3pt !important;
          display: block !important;
        }
      }
    </style>
  </head>
  <body>
    <% if (!data.cvDoc) { %>
    <nav id="download">
      <a
        href="/"
        class="logo no-decoration"
        title="Furkan Tunalı"
        alt="Furkan Tunalı"
        ><em>ft</em></a
      >
      <div class="nav-right">
        <a
          id="download-pdf-link"
          title="Furkan Tunalı CV PDF"
          target="_blank"
          href="https://europe-west1-furkantunali-1043.cloudfunctions.net/downloadAsPDF"
          download="Furkan Tunalı Résumé.pdf"
          ><svg class="button-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18h14v2H5z" />
          </svg>
          Download as PDF</a
        >
        <button
          id="print-button"
          title="Print CV"
          aria-label="Print CV"
        >
          <svg class="button-icon" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"
            />
          </svg>
          Print
        </button>
        <!-- Dark Mode Toggle -->
        <button
          id="theme-toggle"
          class="theme-toggle theme-toggle-cv"
          aria-label="Toggle dark mode"
        >
          <span class="theme-toggle-icon">🌙</span>
        </button>
      </div>
    </nav>
    <% } %>

    <header>
      <div class="page-qr-print" aria-hidden="true">
        <span class="link-qr-print page-qr-print__box"
          ><img id="page-url-qr-image" alt=""
        /></span>
      </div>
      <hgroup>
        <h1><%= meta.title || 'CV' %></h1>
      </hgroup>
    </header>

    <div class="container">
      <div class="intro">
        <div class="left-column">
          <section id="info">
            <h2>Info</h2>
            <ul class="info">
              <% toArray(data.info).forEach(function(item) { %>
              <li>
                <% if (item.label) { %>
                <strong><%= item.label %>:</strong>
                <% } %>
                <%= item.value || '' %>
              </li>
              <% }); %>
            </ul>
          </section>
        </div>
        <div class="right-column">
          <section id="contact">
            <h2>Contact</h2>
            <ul class="contact">
              <% toArray(data.contact).forEach(function(item) { %>
              <li>
                <% if (item.label && item.href) { %>
                <strong><%= item.label %>:</strong>
                <a href="<%= item.href %>" target="_blank" class="link-with-qr">
                  <% if (item.href.indexOf('mailto:') === 0) { %>
                  <span class="link-text-screen"><%= item.text %></span>
                  <span class="link-text-print"
                    ><%= item.text || item.href %></span
                  >
                  <% } else { %>
                  <%= item.text %>
                  <% } %>
                  <% if (shouldRenderLinkQr(item.href)) { %>
                  <span class="link-qr-print" aria-hidden="true"
                    ><img src="<%= getQrCodeUrl(item.href) %>" alt=""
                  /></span>
                  <% } %>
                </a>
                <% } else if (item.label) { %>
                <strong><%= item.label %>:</strong>
                <%= item.text || '' %>
                <% } else if (item.href) { %>
                <strong
                  ><a
                    href="<%= item.href %>"
                    target="_blank"
                    class="link-with-qr"
                    ><%= item.text %>
                    <% if (shouldRenderLinkQr(item.href)) { %>
                    <span class="link-qr-print" aria-hidden="true"
                      ><img src="<%= getQrCodeUrl(item.href) %>" alt=""
                    /></span>
                    <% } %></a
                  ></strong
                >
                <% } else { %>
                <strong><%= item.text || '' %></strong>
                <% } %>
              </li>
              <% }); %>
            </ul>
          </section>
        </div>
      </div>

      <section id="summary">
        <h2>Summary</h2>
        <p><%- data.summary || '' %></p>
      </section>

      <section id="skills">
        <h2>Skills</h2>
        <ul class="skills">
          <% toArray(data.skills).forEach(function(skill) { %>
          <li>
            <strong><%= skill.category || '' %></strong>

            <%= skill.items || '' %>
          </li>
          <% }); %>
        </ul>
      </section>

      <section id="projects">
        <h2>Recent Projects</h2>
        <ul class="projects">
          <% toArray(data.projects).forEach(function(project) { %>
          <li class="project">
            <h3>
              <% if (project.url) { %>
              <strong>
                <a
                  href="<%= project.url %>"
                  target="_blank"
                  class="link-with-qr"
                  ><%= project.name || '' %>
                  <% if (shouldRenderLinkQr(project.url)) { %>
                  <span class="link-qr-print" aria-hidden="true"
                    ><img src="<%= getQrCodeUrl(project.url) %>" alt=""
                  /></span>
                  <% } %>
                </a>
              </strong>
              <% } else { %>
              <strong><%= project.name || '' %></strong>
              <% } %>
              <% if (project.subtitle) { %>
              —
              <%= project.subtitle %>
              <% } %>
            </h3>
            <% toArray(project.links).forEach(function(link) { %>
            <% if (link && link.href) { %>
            <p class="demo-cta">
              <a href="<%= link.href %>" target="_blank" class="link-with-qr">
                <% var isYoutubeProjectLink = isYouTubeHref(link.href); %> <% if
                (isYoutubeProjectLink) { %>
                <span class="link-text-screen"
                  ><%= link.text || link.href %></span
                >
                <span class="link-text-print"
                  ><%= (link.text || link.href) + ' ' %></span
                >
                <% } else { %>
                <span class="link-text-screen"
                  ><%= link.text || link.href %></span
                >
                <span class="link-text-print"><%= link.href %></span>
                <% } %>
                <% if (shouldRenderLinkQr(link.href)) { %>
                <span class="link-qr-print" aria-hidden="true"
                  ><img src="<%= getQrCodeUrl(link.href) %>" alt=""
                /></span>
                <% } %>
              </a>
            </p>
            <% } %>
            <% }); %>
            <% if (project.intro) { %>
            <p><%- project.intro %></p>
            <% } %>
            <% if (toArray(project.bullets).length) { %>
            <ul>
              <% toArray(project.bullets).forEach(function(bullet) { %>
              <li>
                <p><%- bullet %></p>
              </li>
              <% }); %>
            </ul>
            <% } %>
            <% if (project.stack) { %>
            <p>
              <small
                ><strong>Stack:</strong>
                <%= project.stack %></small
              >
            </p>
            <% } %>
          </li>
          <% }); %>
        </ul>
      </section>

      <section id="experiences">
        <h2>Experiences</h2>

        <% var expList = toArray(data.recentExperiences); %>
        <% function estimateExpWeight(exp) { %>
        <% var subroles = toArray(exp.subroles); %>
        <% var bullets = toArray(exp.bullets); %>
        <% var weight = 2; %>
        <% if (subroles.length) { %>
        <% weight += subroles.length * 2; %>
        <% subroles.forEach(function(subrole) { %>
        <% weight += toArray(subrole.bullets).length; %>
        <% }); %>
        <% } else if (bullets.length) { %>
        <% weight += bullets.length; %>
        <% } else if (exp.description) { %>
        <% weight += 2; %>
        <% } %>
        <% return weight; %>
        <% } %>
        <% var leftItems = []; %>
        <% var rightItems = []; %>
        <% if (data.experiencesColumnAutoBalance !== false) { %>
        <% var leftWeight = 0; %>
        <% var rightWeight = 0; %>
        <% expList.forEach(function(exp) { %>
        <% var weight = estimateExpWeight(exp); %>
        <% if (leftWeight <= rightWeight) { %>
        <% leftItems.push(exp); %>
        <% leftWeight += weight; %>
        <% } else { %>
        <% rightItems.push(exp); %>
        <% rightWeight += weight; %>
        <% } %>
        <% }); %>
        <% } else { %>
        <% var splitIdx = data.experiencesColumnSplit != null ? data.experiencesColumnSplit : Math.ceil(expList.length / 2); %>
        <% leftItems = expList.slice(0, splitIdx); %>
        <% rightItems = expList.slice(splitIdx); %>
        <% } %>
        <% function renderExpItems(items) { %>
        <% items.forEach(function(exp) { %>
        <li class="experience">
          <h3>
            <em><%= exp.role || '' %></em>
            at
            <% if (exp.url) { %>
            <a target="_blank" href="<%= exp.url %>" class="link-with-qr"
              ><%- exp.company || '' %>
              <% if (shouldRenderLinkQr(exp.url)) { %>
              <span class="link-qr-print" aria-hidden="true"
                ><img src="<%= getQrCodeUrl(exp.url) %>" alt=""
              /></span>
              <% } %>
            </a>
            <% } else { %>
            <span><%- exp.company || '' %></span>
            <% } %>
            <% if (exp.dates) { %>
            <span class="dates"><%= exp.dates %></span>
            <% } %>
          </h3>
          <% if (toArray(exp.subroles).length) { %>
          <ul>
            <% toArray(exp.subroles).forEach(function(subrole) { %>
            <li>
              <p>
                <strong><%= subrole.title || '' %></strong>
                <% if (subrole.dates) { %>
                <span class="dates"><%= subrole.dates %></span>
                <% } %>
              </p>
              <% if (toArray(subrole.bullets).length) { %>
              <ul>
                <% toArray(subrole.bullets).forEach(function(bullet) { %>
                <li>
                  <p><%- bullet %></p>
                </li>
                <% }); %>
              </ul>
              <% } %>
            </li>
            <% }); %>
          </ul>
          <% } else if (toArray(exp.bullets).length) { %>
          <% toArray(exp.bullets).forEach(function(bullet) { %>
          <p><%- bullet %></p>
          <% }); %>
          <% } else if (exp.description) { %>
          <p><%- exp.description %></p>
          <% } %>
          <% if (exp.stack) { %>
          <p>
            <small
              ><strong>Stack:</strong>
              <%= exp.stack %></small
            >
          </p>
          <% } %>
        </li>
        <% }); %>
        <% } %>

        <div class="experiences-columns">
          <ul class="experiences experiences--left">
            <%- renderExpItems(leftItems) %>
          </ul>
          <ul class="experiences experiences--right">
            <%- renderExpItems(rightItems) %>
          </ul>
        </div>
      </section>

      <section id="experiences-older">
        <h2>Earlier Experiences</h2>

        <div class="experiences-older">
          <% toArray(data.olderExperiences).forEach(function(yearGroup) { %>
          <div class="experience-older__group">
            <h3 class="experience-older__year"><%= yearGroup.year %></h3>
            <div class="experience-older__list">
              <% toArray(yearGroup.experiences).forEach(function(exp) { %>
              <div class="experience-older__entry">
                <div class="experience-older__header">
                  <p class="experience-older__role"><%= exp.role || '' %></p>
                  <% if (exp.url) { %>
                  <p class="experience-older__company">
                    <a
                      target="_blank"
                      href="<%= exp.url %>"
                      class="link-with-qr"
                      ><%- exp.company || '' %>
                      <% if (shouldRenderLinkQr(exp.url)) { %>
                      <span class="link-qr-print" aria-hidden="true"
                        ><img src="<%= getQrCodeUrl(exp.url) %>" alt=""
                      /></span>
                      <% } %>
                    </a>
                  </p>
                  <% } else { %>
                  <p class="experience-older__company">
                    <%- exp.company || '' %>
                  </p>
                  <% } %>
                  <% if (exp.dates) { %>
                  <p class="experience-older__dates"><%= exp.dates %></p>
                  <% } %>
                </div>
                <% if (exp.description) { %>
                <p class="experience-older__description">
                  <%- exp.description %>
                </p>
                <% } %>
              </div>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
      </section>

      <div class="cv-secondary-columns">
        <section id="education" class="cv-secondary-column">
          <h2>Education</h2>

          <ul class="educations">
            <% toArray(data.education).forEach(function(edu) { %>
            <li class="education">
              <h3>
                <em><%= edu.degree || '' %></em> at
                <% if (edu.url) { %>
                <a target="_blank" href="<%= edu.url %>" class="link-with-qr"
                  ><%= (edu.school || '').trim() %><% if
                  (shouldRenderLinkQr(edu.url)) { %><span
                    class="link-qr-print"
                    aria-hidden="true"
                    ><img src="<%= getQrCodeUrl(edu.url) %>" alt="" /></span
                  ><% } %></a
                >
                <% } else { %>
                <span><%= (edu.school || '').trim() %></span>
                <% } %>
                <% if (edu.dates) { %>
                <span class="dates"><%= edu.dates %></span>
                <% } %>
              </h3>
            </li>
            <% }); %>
          </ul>
        </section>

        <section id="interests" class="cv-secondary-column">
          <h2>Interests</h2>
          <p><%- data.interests || '' %></p>
        </section>
      </div>
    </div>

    <% if (!data.cvDoc) { %>
    <button id="back-to-top" aria-label="Back to top" title="Back to top">
      <span aria-hidden="true">&uarr;</span>
    </button>
    <% } %>

    <!-- Environment detection for PDF download URL -->
    <script>
      (function () {
        // Check if we're running locally (development)
        const isLocal =
          window.location.hostname === "localhost" ||
          window.location.hostname === "127.0.0.1" ||
          window.location.hostname.includes("localhost") ||
          window.location.hostname.includes("127.0.0.1");

        const downloadLink = document.getElementById("download-pdf-link");

        // Debug: Log the detection results
        console.log("Hostname:", window.location.hostname);
        console.log("Is Local:", isLocal);
        console.log("Download Link:", downloadLink);

        if (downloadLink && isLocal) {
          // Use Firebase emulator URL for local development
          // Dynamically detect function emulator port (default 5001)
          const functionsPort = "5001"; // Functions emulator default port
          const localUrl = `http://${window.location.hostname}:${functionsPort}/furkantunali-1043/europe-west1/downloadAsPDF`;
          console.log("Setting local URL:", localUrl);
          downloadLink.href = localUrl;
        } else {
          console.log(
            "Using production URL:",
            downloadLink ? downloadLink.href : "No link found",
          );
        }

        // Also log the final URL after any changes
        if (downloadLink) {
          console.log("Final URL:", downloadLink.href);
        }
      })();
    </script>

    <script>
      (function () {
        const printButton = document.getElementById("print-button");
        if (printButton) {
          printButton.addEventListener("click", function () {
            window.print();
          });
        }
      })();
    </script>

    <script>
      (function () {
        var qrImg = document.getElementById("page-url-qr-image");
        if (!qrImg) return;

        var pageUrl = "https://furkantunali.com" + window.location.pathname;
        var qrSrc =
          "https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=0&data=" +
          encodeURIComponent(pageUrl);

        qrImg.src = qrSrc;
      })();
    </script>

    <% if (!data.cvDoc) { %>
    <script>
      (function () {
        var nav = document.getElementById("download");
        var backToTopButton = document.getElementById("back-to-top");

        if (!nav && !backToTopButton) return;

        function updateStickyShadow() {
          var isScrolled = window.scrollY > 0;

          if (nav) {
            nav.classList.toggle("scrolled", isScrolled);
          }

          if (document.body) {
            document.body.classList.toggle("nav-scrolled", isScrolled);
          }

          if (backToTopButton) {
            backToTopButton.classList.toggle("visible", window.scrollY > 500);
          }
        }

        updateStickyShadow();
        window.addEventListener("scroll", updateStickyShadow, {
          passive: true,
        });

        if (backToTopButton) {
          backToTopButton.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
          });
        }
      })();
    </script>
    <% } %>

    <% if (!data.cvDoc) { %>

    <!-- Dark Mode Toggle Script -->
    <script>
      (function () {
        // Theme management
        const THEME_KEY = "theme";
        const THEME_LIGHT = "light";
        const THEME_DARK = "dark";
        const THEME_AUTO = "auto";

        // Get elements
        const html = document.documentElement;
        const toggle = document.getElementById("theme-toggle");
        const icon = document.querySelector(".theme-toggle-icon");

        // Get system preference
        function getSystemTheme() {
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? THEME_DARK
            : THEME_LIGHT;
        }

        // Get stored theme or default to system
        function getStoredTheme() {
          const stored = localStorage.getItem(THEME_KEY);
          if (stored === THEME_LIGHT || stored === THEME_DARK) {
            return stored;
          }
          return getSystemTheme();
        }

        // Apply theme
        function applyTheme(theme) {
          const isDark = theme === THEME_DARK;

          if (isDark) {
            html.classList.add("dark-theme");
            icon.textContent = "☀️";
          } else {
            html.classList.remove("dark-theme");
            icon.textContent = "🌙";
          }
        }

        // Toggle theme
        function toggleTheme() {
          const currentTheme = getStoredTheme();
          const newTheme =
            currentTheme === THEME_DARK ? THEME_LIGHT : THEME_DARK;

          localStorage.setItem(THEME_KEY, newTheme);
          applyTheme(newTheme);
        }

        // Initialize theme
        const initialTheme = getStoredTheme();
        applyTheme(initialTheme);

        // Add toggle event listener
        if (toggle) {
          toggle.addEventListener("click", toggleTheme);
        }

        // Listen for system theme changes
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", function () {
            if (
              !localStorage.getItem(THEME_KEY) ||
              localStorage.getItem(THEME_KEY) === THEME_AUTO
            ) {
              applyTheme(getSystemTheme());
            }
          });
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=UA-60053491-1"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "UA-60053491-1");
    </script>
    <% } %>
  </body>
</html>
