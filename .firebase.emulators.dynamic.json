{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "site": "furkantunali-1043",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/resume.html",
        "destination": "/cv",
        "type": 301
      },
      {
        "source": "/cv.html",
        "destination": "/cv",
        "type": 301
      },
      {
        "source": "/CV",
        "destination": "/cv",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/cv",
        "destination": "/cv.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "hub": {
      "port": 4410
    },
    "ui": {
      "enabled": true,
      "port": 4010
    },
    "logging": {
      "port": 4510
    },
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 8088
    },
    "storage": {
      "port": 9199
    },
    "singleProjectMode": true
  }
}